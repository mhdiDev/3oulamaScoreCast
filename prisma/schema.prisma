generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Locale {
  fr
  en
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum NotificationType {
  REMINDER
  RESULT
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum NotificationStatus {
  SENT
  FAILED
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique @db.VarChar(50)
  passwordHash         String
  avatarUrl            String?
  locale               Locale    @default(fr)
  role                 Role      @default(USER)
  emailNotifications   Boolean   @default(true)
  pushSubscription     Json?
  resetToken           String?
  resetTokenExpiresAt  DateTime?
  createdAt            DateTime  @default(now())

  predictions          Prediction[]
  invitationsCreated   Invitation[]          @relation("CreatedBy")
  invitationsUsed      Invitation[]          @relation("UsedBy")
  groupsCreated        Group[]
  groupMembers         GroupMember[]
  leaderboardSnapshots LeaderboardSnapshot[]
  notificationLogs     NotificationLog[]
  scoringRuleUpdates   ScoringRule[]
}

model Invitation {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  email       String?
  createdBy   User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String
  group       Group?    @relation(fields: [groupId], references: [id])
  groupId     String?
  usedBy      User?     @relation("UsedBy", fields: [usedById], references: [id])
  usedById    String?
  expiresAt   DateTime
  usedAt      DateTime?
}

model Group {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(100)
  createdBy   User          @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime      @default(now())

  members              GroupMember[]
  invitations          Invitation[]
  leaderboardSnapshots LeaderboardSnapshot[]
}

model GroupMember {
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime @default(now())

  @@id([groupId, userId])
}

model Team {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  nameEn      String  @db.VarChar(100)
  code        String  @unique @db.VarChar(3)
  flagUrl     String
  group       String? @db.VarChar(1)
  fifaRanking Int?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id         String      @id @default(uuid())
  externalId String      @unique @db.VarChar(50)
  homeTeam   Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId String
  awayTeam   Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId String
  kickoffAt  DateTime
  cutoffAt   DateTime
  stage      Stage
  group      String?     @db.VarChar(1)
  stadium    String?     @db.VarChar(100)
  city       String?     @db.VarChar(100)
  homeScore  Int?
  awayScore  Int?
  status     MatchStatus @default(SCHEDULED)

  predictions      Prediction[]
  notificationLogs NotificationLog[]
}

model Prediction {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, matchId])
}

model ScoringRule {
  id              Int      @id @default(1)
  exactScore      Int      @default(3)
  correctResult   Int      @default(1)
  wrongPrediction Int      @default(0)
  updatedAt       DateTime @default(now()) @updatedAt
  updatedBy       User?    @relation(fields: [updatedById], references: [id])
  updatedById     String?
}

model LeaderboardSnapshot {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  group          Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId        String?
  totalPoints    Int      @default(0)
  exactScores    Int      @default(0)
  correctResults Int      @default(0)
  currentStreak  Int      @default(0)
  rank           Int
  computedAt     DateTime @default(now())

  @@unique([userId, groupId])
}

model NotificationLog {
  id      String              @id @default(uuid())
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  type    NotificationType
  channel NotificationChannel
  match   Match               @relation(fields: [matchId], references: [id])
  matchId String
  sentAt  DateTime            @default(now())
  status  NotificationStatus
}
